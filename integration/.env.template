# =============================================================================
# MotoGP Analytics Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure for your environment
# 
# Usage:
#   cp integration/.env.template .env
#   # Edit .env with your specific configuration
#   source .env

# =============================================================================
# GLOBAL PLATFORM SETTINGS
# =============================================================================
PLATFORM_NAME="MotoGP Analytics Platform"
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=motogp_analytics
DB_USER=motogp_user
DB_PASSWORD=motogp_secure_password

# Database Connection Pool
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30

# Database URL (auto-constructed)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# =============================================================================
# API BACKEND CONFIGURATION
# =============================================================================
# FastAPI Settings
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# API Security
API_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Performance
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:3001
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=60

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# Streamlit Dashboard Settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
DASHBOARD_TITLE="MotoGP Analytics Dashboard"

# Dashboard Features
DASHBOARD_AUTO_REFRESH_INTERVAL=300  # seconds
DASHBOARD_ENABLE_DEMO_MODE=true
DASHBOARD_ENABLE_REALTIME=true

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
# Redis Cache Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache Settings
CACHE_TTL=3600  # 1 hour in seconds
CACHE_ENABLED=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus Monitoring
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

# Grafana Dashboard
GRAFANA_HOST=localhost
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Logging Configuration
LOG_STRUCTURED=true
LOG_INCLUDE_REQUEST_ID=true
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/motogp-platform.log

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Security Settings
SECURITY_SECRET_KEY=${API_SECRET_KEY}
SECURITY_JWT_ALGORITHM=${API_ALGORITHM}
SECURITY_JWT_EXPIRE_MINUTES=${API_ACCESS_TOKEN_EXPIRE_MINUTES}

# CORS Configuration
CORS_ORIGINS=${API_ALLOWED_ORIGINS}
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE
CORS_HEADERS=*

# =============================================================================
# DATA SCIENCE CONFIGURATION
# =============================================================================
# Jupyter Configuration
JUPYTER_HOST=0.0.0.0
JUPYTER_PORT=8888
JUPYTER_TOKEN=your-jupyter-token-for-security

# Data Processing
DATA_RAW_PATH=./data/raw
DATA_INTERIM_PATH=./data/interim
DATA_PROCESSED_PATH=./data/processed

# Model Configuration
MODEL_RANDOM_SEED=42
MODEL_TEST_SIZE=0.2
MODEL_CV_FOLDS=5

# =============================================================================
# INFRASTRUCTURE CONFIGURATION
# =============================================================================
# Docker Configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
DOCKER_BUILD_ARGS=

# Kubernetes Configuration
K8S_NAMESPACE=motogp-analytics
K8S_CLUSTER_NAME=motogp-cluster
K8S_CONTEXT=local

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development Tools
DEV_AUTO_RELOAD=true
DEV_DEBUG_MODE=false
DEV_PROFILER_ENABLED=false

# Testing Configuration
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/motogp_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_API_BASE_URL=http://localhost:8000

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Production-specific settings (uncomment for production)
# ENVIRONMENT=production
# LOG_LEVEL=WARNING
# API_DEBUG=false
# DASHBOARD_ENABLE_DEMO_MODE=false
# DEV_AUTO_RELOAD=false
# DB_MIN_CONNECTIONS=5
# DB_MAX_CONNECTIONS=50

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Third-party integrations (if needed)
# KAGGLE_API_KEY=your-kaggle-api-key
# KAGGLE_USERNAME=your-kaggle-username

# Email notifications (if enabled)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=motogp-analytics-backups

# =============================================================================
# USAGE NOTES
# =============================================================================
# 1. Never commit the actual .env file to version control
# 2. Each environment (dev/staging/prod) should have its own .env
# 3. Use strong passwords and secrets in production
# 4. Update DEFAULT values in this template as needed
# 5. Document any new variables you add