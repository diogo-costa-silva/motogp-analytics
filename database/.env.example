# MotoGP Analytics Database Configuration
# Copy this file to .env and update with your database credentials

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=motogp_analytics
DB_USER=postgres
DB_PASSWORD=your_password_here

# Development vs Production
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/motogp_db.log

# API Configuration (for future use)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Cache Configuration (Redis - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0